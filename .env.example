# ─────────────────────────────────────────────
#  Hevy Fatigue Monitor — Environment Variables
#  Copy this file to .env and fill in your values.
#    cp .env.example .env
#  Never commit the .env file to version control.
# ─────────────────────────────────────────────

# Your Hevy PRO API key.
# Get it from: https://hevy.com/settings (Developer section)
HEVY_API_KEY=your_api_key_here

# Database path (optional — only set this if you are NOT using Docker).
# Docker sets this automatically via docker-compose.yml.
# DB_PATH=./hevy_fatigue.db
